# =============================================================================
# VectorForge - Combined Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize the values for your environment.
# All settings have sensible defaults if not specified.
#
# This file contains configuration for:
#   1. VectorForge Engine (vectorforge/)
#   2. VectorForge MCP Server (vectorforge_mcp/)


################################################################################
# VECTORFORGE ENGINE CONFIGURATION
################################################################################

# =============================================================================
# Model Configuration
# =============================================================================

# Sentence transformer model for generating embeddings
# Examples: all-MiniLM-L6-v2, all-mpnet-base-v2, paraphrase-multilingual-MiniLM-L12-v2
VF_MODEL_NAME="all-MiniLM-L6-v2"

# Dimension of the embedding vectors (must match the model)
# all-MiniLM-L6-v2: 384, all-mpnet-base-v2: 768
VF_EMBEDDING_DIMENSION=384

# =============================================================================
# Storage Configuration
# =============================================================================

# Maximum valid path length for save/load functionality
VF_MAX_PATH_LEN=4096

# Maximum filename length (including extension)
# Keep under filesystem limits (typically 255)
VF_MAX_FILENAME_LENGTH=255

# =============================================================================
# Content Validation
# =============================================================================

# Minimum character length for document content
VF_MIN_CONTENT_LENGTH=1

# Maximum character length for document content
# Range: MIN_CONTENT_LENGTH - 100000
VF_MAX_CONTENT_LENGTH=10000

# Maximum number of documents per batch add or batch delete request
# Range: 1-1000, larger batches improve throughput but increase memory
VF_MAX_BATCH_SIZE=100

# Minimum character length for search queries
VF_MIN_QUERY_LENGTH=1

# Maximum character length for search queries
# Range: MIN_QUERY_LENGTH - 10000
VF_MAX_QUERY_LENGTH=2000

# =============================================================================
# Document Processing
# =============================================================================

# Default number of characters per chunk when splitting documents
# Range: 100-5000, adjust based on your content and model context window
VF_DEFAULT_CHUNK_SIZE=500

# Default number of overlapping characters between consecutive chunks
# Range: 0-500, overlap helps maintain context across chunk boundaries
VF_DEFAULT_CHUNK_OVERLAP=50

# =============================================================================
# Search Configuration
# =============================================================================

# Default number of search results to return
# Range: MIN_TOP_K - MAX_TOP_K
VF_DEFAULT_TOP_K=10

# Minimum value for top_k parameter
VF_MIN_TOP_K=1

# Maximum value for top_k parameter
VF_MAX_TOP_K=100

# =============================================================================
# Metrics Configuration
# =============================================================================

# Maximum number of query times to retain for percentile calculations
# Range: 100-10000, higher values provide better statistics
VF_MAX_QUERY_HISTORY=1000

# TTL in minutes for the cached ChromaDB disk size calculation
# Range: 1-60, lower values provide fresher data but more I/O
VF_DISK_SIZE_TTL_MINS=5

# =============================================================================
# Supported File Types
# =============================================================================

# Comma-separated list of supported file extensions for upload
# Each extension must start with a dot (e.g., .pdf,.txt,.md)
VF_SUPPORTED_FILE_EXTENSIONS=".pdf,.txt"

# =============================================================================
# ChromaDB Configuration
# =============================================================================

# Directory for ChromaDB persistent storage
# Can be relative (./data/chroma) or absolute (/var/vectorforge/chroma)
CHROMA_DATA_DIR="./data/chroma"

# Directory for HuggingFace model cache
# Models are downloaded here on first use
HF_HOME="~/.cache/huggingface"

# Batch size for HNSW configuration migration (collection-level recreation)
# Range: 100-10000, larger batches speed up migration but use more memory
VF_MIGRATION_BATCH_SIZE=1000

# =============================================================================
# Collection Management Configuration
# =============================================================================

# Maximum number of collections allowed per instance
# Range: 1-1000, adjust based on your use case and available resources
VF_MAX_COLLECTIONS=100

# Default collection when none specified
VF_DEFAULT_COLLECTION_NAME="vectorforge"

# FIFO cache size for collection engines
# Range: 1-100, higher values reduce I/O but increase memory usage
VF_COLLECTION_CACHE_SIZE=50

# Maximum length for collection names
# Range: MIN_COLLECTION_NAME_LENGTH - 255
VF_MAX_COLLECTION_NAME_LENGTH=64

# Minimum length for collection names
VF_MIN_COLLECTION_NAME_LENGTH=3

# Maximum character length of a collection's description
# Range: 0-5000
VF_MAX_DESCRIPTION_LENGTH=500

# Regex pattern for valid collection names
# Must start/end with alphanumeric, can contain alphanumeric, underscore, hyphen
VF_COLLECTION_NAME_PATTERN="^[a-zA-Z0-9][a-zA-Z0-9_-]*[a-zA-Z0-9]$"

# Maximum number of key-value pairs for collection metadata
# Range: 1-100
VF_MAX_METADATA_PAIRS=20


################################################################################
# VECTORFORGE MCP SERVER CONFIGURATION
################################################################################

# =============================================================================
# Server Metadata
# =============================================================================

# Display name for the MCP server
VF_SERVER_NAME="VectorForge MCP Server"

# Short description of the MCP server reported to MCP clients
VF_SERVER_DESCRIPTION="Model Context Protocol server for VectorForge vector database"

# =============================================================================
# VectorForge API Connection
# =============================================================================

# Base URL of the VectorForge REST API
# Update if running VectorForge on a different host/port
# NOTE: This should match where your VectorForge engine is running
VECTORFORGE_API_BASE_URL="http://localhost:3001"

# =============================================================================
# Logging Configuration (API server + MCP server)
# =============================================================================

# Logging verbosity level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO or WARNING for production
VF_LOG_LEVEL="INFO"

# Path to log file for the API server
# Logs are stored in JSON format with automatic rotation (10MB files, 5 backups)
# MCP server default: .logs/vectorforge_mcp.log
VF_LOG_FILE=".logs/vectorforge.log"

# Enable JSON console output (useful for production log aggregation)
# Options: true, false
# Set to true if using structured log collection systems (e.g., ELK, Splunk)
VF_LOG_JSON_CONSOLE="false"

# Maximum text length for sanitization in logs (prevents sensitive data exposure)
# Long text fields (queries, document content) are truncated with "..." to this length
# Range: 50-1000
VF_LOG_MAX_TEXT_LEN=100

# Maximum size per log file before rotation (in bytes)
# Default: 10485760 (10MB)
# Range: 1048576-104857600 (1MB-100MB)
VF_LOG_MAX_BYTES=10485760

# Number of backup log files to keep during rotation
# Default: 5 (total disk usage = max_bytes * (backup_count + 1))
# Example: 10MB * 6 = 60MB total
# Range: 0-20
VF_LOG_BACKUP_COUNT=5
