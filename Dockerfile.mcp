FROM python:3.11-slim AS base

ENV PYTHONBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y \
    curl \
    netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

FROM base AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

COPY pyproject.toml uv.lock ./
COPY vectorforge/ ./vectorforge/
COPY vectorforge_mcp/ ./vectorforge_mcp/

RUN uv sync --frozen --no-dev --group mcp

FROM base AS production

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv

COPY vectorforge/ ./vectorforge
COPY vectorforge_mcp/ ./vectorforge_mcp/

ENV MCP_HOST=0.0.0.0 \
    MCP_PORT=3002 \
    VECTORFORGE_API_BASE_URL=http://localhost:3001 \
    LOG_LEVEL=INFO \
    PATH="/app/.venv/bin:$PATH"

# Use nc to verify MCP server is listening
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD nc -z localhost 3002 || exit 1

RUN useradd -m -u 1000 vectorforge && \
    chown -R vectorforge:vectorforge /app
USER vectorforge

CMD ["vectorforge-mcp"]
